{
  "version": 2,
  "builds": [
    {
      "src": "build/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/summarize",
      "dest": "/api/summarize"
    },
    {
      "src": "/(.*)",
      "dest": "build/$1"
    }
  ]
}
